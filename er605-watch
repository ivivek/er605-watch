#!/usr/bin/env bash
# =============================================================
# ER605 Dual-WAN Connectivity Checker (TP-Link Omada CLI)
# Tested on: ER605 v2.0, firmware 2.3.0
#
# Config precedence (highest first): CLI flag > inline env var > env file.
#   Env file : .env next to this script (git-ignored). See .env.example.
# Usage: ./er605-watch [--trace] [--trace-only] [--fast] [--json]
#        ./er605-watch <password> [flags]
#        ./er605-watch --host <ip> <password> [flags]
#        ROUTER_IP=... ROUTER_PASS=... ./er605-watch
#   --trace / -t  : full check, then also run a traceroute to the public target (slow)
#   --trace-only  : run the traceroute but skip the pings (WAN status from link state)
#   --fast / -f   : link status only, skip pings/traceroute (~3s, no connectivity)
#   --json / -j   : emit a JSON object on stdout (needs jq); progress -> stderr
# Exit codes: 0 all WANs up · 1 one down · 2 both down · 3 router unreachable
#             · 4 usage/config error
# =============================================================

# ─── CONFIG ───────────────────────────────────────────────────
# Remember values already set in the environment (these win over the env file).
_env_ROUTER_IP="${ROUTER_IP:-}"; _env_ROUTER_PASS="${ROUTER_PASS:-}"

# Load the env file if present (git-ignored; holds site-specific values).
CONFIG_FILE="${CONFIG_FILE:-$(dirname "$0")/.env}"
[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

# Inline env vars override the file.
[[ -n "$_env_ROUTER_IP"   ]] && ROUTER_IP="$_env_ROUTER_IP"
[[ -n "$_env_ROUTER_PASS" ]] && ROUTER_PASS="$_env_ROUTER_PASS"

ROUTER_USER="${ROUTER_USER:-admin}"
ROUTER_PORT="${ROUTER_PORT:-22}"

# Which switchports are your WANs (ER605 v2: ports 1-5)
WAN1_PORT="${WAN1_PORT:-1}"
WAN2_PORT="${WAN2_PORT:-2}"

# WAN gateways to ping for per-link health (the CLI ping can't be bound to a
# WAN, so we ping each WAN's own gateway — traffic to it can only egress that
# link). Blank by default: the script auto-discovers them from "show interface
# switchport" so no site-specific IPs are needed. Set both (here or in .env) to
# run everything in ONE SSH login instead of two (saves ~1s); the script then
# warns on live-vs-config drift.
WAN1_GW="${WAN1_GW:-}"
WAN2_GW="${WAN2_GW:-}"

# Friendly ISP labels per WAN (optional, site-specific → keep in .env). When set,
# output shows e.g. "Airtel Fiber (WAN1)" instead of bare "WAN1". Unset → WANn.
WAN1_ISP="${WAN1_ISP:-}"
WAN2_ISP="${WAN2_ISP:-}"

# Public IP to test overall internet reachability (follows the active route)
PING_PUBLIC="${PING_PUBLIC:-8.8.8.8}"

# CLI args (override everything): [--host <ip>] [--trace] [--trace-only] [--fast] [--json] [<password>].
# Traceroute follows the active route only, so it traces whichever WAN carries it.
DO_TRACE="${DO_TRACE:-0}"; FAST_MODE="${FAST:-0}"; JSON_MODE="${JSON:-0}"
TRACE_ONLY="${TRACE_ONLY:-0}"
PASS_ARG=""; HOST_ARG=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --trace|-t)    DO_TRACE=1; shift ;;
        --trace-only)  DO_TRACE=1; TRACE_ONLY=1; shift ;;
        --fast|-f)     FAST_MODE=1; shift ;;
        --json|-j)     JSON_MODE=1; shift ;;
        --host|-H)     HOST_ARG="$2"; shift 2 ;;
        *)             PASS_ARG="$1"; shift ;;
    esac
done
[[ -n "$HOST_ARG" ]] && ROUTER_IP="$HOST_ARG"
[[ -n "$PASS_ARG" ]] && ROUTER_PASS="$PASS_ARG"

# Fast mode skips all connectivity tests (and therefore traceroute).
DO_PINGS=1
[[ $FAST_MODE -eq 1 ]] && { DO_PINGS=0; DO_TRACE=0; }
# Trace-only: run the traceroute but skip the per-WAN/internet pings (WAN up/down
# then comes from link status, like fast mode). Applied after fast so it wins.
[[ $TRACE_ONLY -eq 1 ]] && { DO_PINGS=0; DO_TRACE=1; }

if [[ -z "$ROUTER_IP" ]]; then
    echo "ERROR: no router IP. Set ROUTER_IP in $CONFIG_FILE, pass --host <ip>, or export ROUTER_IP." >&2
    exit 4
fi
if [[ -z "$ROUTER_PASS" ]]; then
    echo "ERROR: no password. Set ROUTER_PASS in $CONFIG_FILE, pass it as an arg, or export ROUTER_PASS." >&2
    exit 4
fi

# ─── COLORS ───────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

# ─── SSH / CLI DRIVER ─────────────────────────────────────────
# The ER605 CLI is interactive (no exec mode) and gives no completion signal,
# so we drive it with `expect`: type the password, enter `enable`, then send
# each command and wait for the `#` prompt to return — no blind sleeps. ER605
# runs Dropbear (legacy ssh-rsa host key), so we re-enable that algorithm.
if ! command -v expect &>/dev/null; then
    echo "ERROR: expect not found. Install it: sudo apt-get install expect" >&2
    exit 4
fi
if [[ $JSON_MODE -eq 1 ]] && ! command -v jq &>/dev/null; then
    echo "ERROR: --json needs jq. Install it: sudo apt-get install jq" >&2
    exit 4
fi

# Progress goes to stderr so stdout stays clean (pure JSON in --json mode).
progress() { echo -e "$@" >&2; }

# run_cli "cmd" "cmd" ...
# Runs each command in privileged mode and returns the raw session output.
# Waits on the prompt (not the clock), so it's as fast as the router responds.
run_cli() {
    CLI_CMDS="$(printf '%s\n' "$@")" \
    EXP_HOST="$ROUTER_IP" EXP_USER="$ROUTER_USER" \
    EXP_PASS="$ROUTER_PASS" EXP_PORT="$ROUTER_PORT" \
    expect -f - <<'EXPECT' 2>/dev/null | tr -d '\r'
        set timeout 90        ;# ceiling only (we return on prompt); high for slow tracert
        set pass $env(EXP_PASS)
        set cmds [split $env(CLI_CMDS) "\n"]

        spawn ssh -tt \
            -o StrictHostKeyChecking=no -o ConnectTimeout=10 \
            -o HostKeyAlgorithms=+ssh-rsa -o PubkeyAcceptedAlgorithms=+ssh-rsa \
            -p $env(EXP_PORT) $env(EXP_USER)@$env(EXP_HOST)

        expect "assword:"      ;# password prompt
        send "$pass\r"
        expect ">"             ;# base CLI prompt
        send "enable\r"
        expect "#"             ;# privileged prompt

        foreach c $cmds {
            if {$c eq ""} continue
            send "$c\r"
            expect "#"         ;# command done when prompt returns
        }
        # We already have all command output. The router doesn't reliably send
        # EOF on logout (expect eof would block the full timeout), so request
        # logout and force-close our side immediately.
        send "exit\r"; send "exit\r"
        close; wait
EXPECT
}

# Extract the output block for a given command from raw session output.
extract() {
    local raw="$1" cmd="$2"
    awk -v marker="#$cmd" '
        index($0, marker)==1 { grab=1; next }
        grab && (substr($0,1,1)=="#" || substr($0,1,1)==">") { grab=0 }
        grab { print }
    ' <<< "$raw"
}

# Pull "Field......Value" (dots or colon+dots as separator) out of a block.
get_field() {
    local block="$1" label="$2"
    printf '%s\n' "$block" | grep -i "$label" | head -1 \
        | sed -E 's/\.{2,}/\x01/' | cut -d$'\x01' -f2 \
        | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//'
}

parse_loss() { grep -oP '\d+(?=% packet loss)' <<< "$1" | head -1; }
parse_rtt()  { grep -oP 'min/avg/max = \K[0-9.]+/[0-9.]+/[0-9.]+' <<< "$1" | head -1 | awk -F/ '{print $2}'; }

# ─── OUTPUT ───────────────────────────────────────────────────
print_header() {
    echo ""
    echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════╗${RESET}"
    echo -e "${BOLD}${CYAN}║       ER605 Dual-WAN Status Check        ║${RESET}"
    echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════╝${RESET}"
    echo -e "  Router : ${ROUTER_IP}"
    echo -e "  Time   : $(date '+%Y-%m-%d %H:%M:%S')"
    echo ""
}

# Extract just the default gateway from a switchport block.
wan_gateway() { get_field "$1" "Default Gateway"; }

# Display one WAN's parsed details (stdout). If $3 (the configured gateway) is
# set and differs from the live gateway, warn about config drift.
show_wan() {
    local block="$1" label="$2" cfg_gw="$3" isp="$4"
    local hdr="${label} (switchport)"
    [[ -n "$isp" ]] && hdr="${isp} (${label})"
    local name type status proto ip gw dns
    name=$(get_field "$block"   "Port name")
    type=$(get_field "$block"   "Vlan type")
    status=$(get_field "$block" "Routing Interface Status")
    proto=$(get_field "$block"  "Proto")
    ip=$(get_field "$block"     "Primary IP")
    gw=$(get_field "$block"     "Default Gateway")
    dns=$(get_field "$block"    "Primary DNS")

    echo -e "${BOLD}── ${hdr} ───────────────────────${RESET}"
    echo -e "  Port Name : ${name:-?}"
    echo -e "  Type      : ${type:-?}"
    if [[ "${status^^}" == "UP" ]]; then
        echo -e "  Status    : ${GREEN}UP${RESET}"
    elif [[ -n "$status" ]]; then
        echo -e "  Status    : ${RED}${status}${RESET}"
    else
        echo -e "  Status    : ${YELLOW}unknown${RESET}"
    fi
    echo -e "  Proto     : ${proto:-?}"
    echo -e "  IP        : ${ip:-—}"
    echo -e "  Gateway   : ${gw:-—}"
    if [[ -n "$cfg_gw" && -n "$gw" && "$cfg_gw" != "$gw" ]]; then
        echo -e "  ${YELLOW}⚠ configured ${cfg_gw} ≠ live ${gw} — update WAN_GW in config${RESET}"
    fi
    echo -e "  DNS       : ${dns:-—}"
    echo ""
}

ping_result() {
    local block="$1" label="$2" target="$3"
    local loss rtt
    loss=$(parse_loss "$block")
    rtt=$(parse_rtt "$block")
    if [[ "$loss" == "0" ]]; then
        echo -e "  ${label} → ${target} : ${GREEN}● ONLINE${RESET} (0% loss, avg ${rtt}ms)"
    elif [[ -n "$loss" ]]; then
        echo -e "  ${label} → ${target} : ${YELLOW}● DEGRADED${RESET} (${loss}% loss)"
    else
        echo -e "  ${label} → ${target} : ${RED}● OFFLINE${RESET} (no response)"
    fi
}

# Summarise a single per-WAN gateway ping line.
summarise_gw() {
    local praw="$1" gw="$2" label="$3"
    if [[ -n "$gw" && "$gw" != "0.0.0.0" ]]; then
        ping_result "$(extract "$praw" "ping ${gw}")" "$label" "$gw"
    else
        echo -e "  ${label} : ${RED}● no gateway (down?)${RESET}"
    fi
}

# Classify a ping's packet-loss into online / degraded / offline.
ping_state() {
    local loss="$1"
    if   [[ -z "$loss" ]];                  then echo offline
    elif [[ "$loss" -ge 100 ]] 2>/dev/null; then echo offline
    elif [[ "$loss" -gt 0   ]] 2>/dev/null; then echo degraded
    else echo online
    fi
}
# Emit a value as a JSON number, or `null` if empty (for jq --argjson).
jnum() { [[ -n "$1" ]] && printf '%s' "$1" || printf 'null'; }

# Build one WAN's JSON object. Args: port name type status proto ip live_gw
#                                     state ping_target loss rtt isp
wan_json() {
    local ping='null'
    if [[ $DO_PINGS -eq 1 ]]; then
        ping=$(jq -n --arg t "$9" --argjson loss "$(jnum "${10}")" \
                     --argjson rtt "$(jnum "${11}")" --arg st "$8" \
            '{target:$t, loss_pct:$loss, rtt_ms:$rtt, state:$st, online:($st!="offline")}')
    fi
    jq -n --argjson port "$1" --arg name "$2" --arg isp "${12}" --arg type "$3" --arg status "$4" \
          --arg proto "$5" --arg ip "$6" --arg gw "$7" --arg st "$8" --argjson ping "$ping" \
        '{port:$port, name:$name, isp:$isp, type:$type, status:$status, proto:$proto,
          ip:$ip, gateway:$gw, up:($st!="offline"), ping:$ping}'
}

# ─── MAIN ─────────────────────────────────────────────────────
[[ $JSON_MODE -eq 0 ]] && print_header

# Discover mode: a WAN gateway left blank → learn it from the switchport output
# (costs a 2nd login). Both set → fold pings into the first login.
DISCOVER=0
[[ -z "$WAN1_GW" || -z "$WAN2_GW" ]] && DISCOVER=1

CMDS=(
    "show interface switchport ${WAN1_PORT}"
    "show interface switchport ${WAN2_PORT}"
    "show arp"
)
if [[ $DO_PINGS -eq 1 && $DISCOVER -eq 0 ]]; then
    [[ "$WAN1_GW" != "0.0.0.0" ]] && CMDS+=("ping ${WAN1_GW}")
    [[ "$WAN2_GW" != "0.0.0.0" ]] && CMDS+=("ping ${WAN2_GW}")
    CMDS+=("ping ${PING_PUBLIC}")
    [[ $DO_TRACE -eq 1 ]] && CMDS+=("tracert ${PING_PUBLIC}")
elif [[ $DO_PINGS -eq 0 && $DO_TRACE -eq 1 ]]; then
    # Trace-only: no pings, just the trace. Target is the fixed public IP, so no
    # gateway discovery is needed — it all fits in this single login.
    CMDS+=("tracert ${PING_PUBLIC}")
fi

# If the trace runs in this login (trace-only, or full --trace with gateways set),
# say so — it's slow and the expect driver shows nothing until it finishes.
if [[ $DO_TRACE -eq 1 && ( $TRACE_ONLY -eq 1 || $DISCOVER -eq 0 ) ]]; then
    progress "${YELLOW}► Querying router + tracing route to ${PING_PUBLIC} (slow — dead hops time out, up to ~60s; output appears when done)...${RESET}"
else
    progress "${YELLOW}► Querying router...${RESET}"
fi
RAW=$(run_cli "${CMDS[@]}")

if ! grep -q '#' <<< "$RAW"; then
    if [[ $JSON_MODE -eq 1 ]]; then
        jq -n --arg router "$ROUTER_IP" \
            '{router:$router, overall:"unreachable",
              error:"could not get a CLI prompt — check IP, password, SSH access"}'
    else
        echo -e "${RED}✗ Could not get a CLI prompt. Check IP, password, and SSH access.${RESET}"
    fi
    exit 3
fi

WAN1_BLOCK=$(extract "$RAW" "show interface switchport ${WAN1_PORT}")
WAN2_BLOCK=$(extract "$RAW" "show interface switchport ${WAN2_PORT}")
ARP_BLOCK=$(extract "$RAW" "show arp")

# Parse each WAN's fields (tab-delimited; CLI fields never contain tabs).
read_wan() {
    local b="$1"
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s' \
        "$(get_field "$b" "Port name")"  "$(get_field "$b" "Vlan type")" \
        "$(get_field "$b" "Routing Interface Status")" "$(get_field "$b" "Proto")" \
        "$(get_field "$b" "Primary IP")" "$(get_field "$b" "Default Gateway")" \
        "$(get_field "$b" "Primary DNS")"
}
IFS=$'\t' read -r w1_name w1_type w1_status w1_proto w1_ip w1_gw w1_dns < <(read_wan "$WAN1_BLOCK")
IFS=$'\t' read -r w2_name w2_type w2_status w2_proto w2_ip w2_gw w2_dns < <(read_wan "$WAN2_BLOCK")

# Gateway to test = configured value if set, else the live one from switchport.
g1="${WAN1_GW:-$w1_gw}"; g2="${WAN2_GW:-$w2_gw}"

# Friendly per-WAN label for the summary ("ISP" if set, else "WANn").
lbl1="${WAN1_ISP:-WAN1}"; lbl2="${WAN2_ISP:-WAN2}"

# Connectivity tests (skipped in --fast). Run a 2nd login if not already done.
PRAW="$RAW"
if [[ $DO_PINGS -eq 1 && $DISCOVER -eq 1 ]]; then
    if [[ $DO_TRACE -eq 1 ]]; then
        progress "${YELLOW}► Testing connectivity + tracing route (slow — up to ~60s; output appears when done)...${RESET}"
    else
        progress "${YELLOW}► Testing connectivity...${RESET}"
    fi
    PING_CMDS=()
    [[ -n "$g1" && "$g1" != "0.0.0.0" ]] && PING_CMDS+=("ping ${g1}")
    [[ -n "$g2" && "$g2" != "0.0.0.0" ]] && PING_CMDS+=("ping ${g2}")
    PING_CMDS+=("ping ${PING_PUBLIC}")
    [[ $DO_TRACE -eq 1 ]] && PING_CMDS+=("tracert ${PING_PUBLIC}")
    PRAW=$(run_cli "${PING_CMDS[@]}")
fi

# Derive per-WAN + internet state.
if [[ $DO_PINGS -eq 1 ]]; then
    w1_loss=$(parse_loss "$(extract "$PRAW" "ping ${g1}")");          w1_rtt=$(parse_rtt "$(extract "$PRAW" "ping ${g1}")")
    w2_loss=$(parse_loss "$(extract "$PRAW" "ping ${g2}")");          w2_rtt=$(parse_rtt "$(extract "$PRAW" "ping ${g2}")")
    inet_loss=$(parse_loss "$(extract "$PRAW" "ping ${PING_PUBLIC}")"); inet_rtt=$(parse_rtt "$(extract "$PRAW" "ping ${PING_PUBLIC}")")
    w1_state=$(ping_state "$w1_loss"); w2_state=$(ping_state "$w2_loss"); inet_state=$(ping_state "$inet_loss")
else
    # Fast mode: liveness from the switchport "Routing Interface Status".
    [[ "${w1_status^^}" == "UP" ]] && w1_state=online || w1_state=offline
    [[ "${w2_status^^}" == "UP" ]] && w2_state=online || w2_state=offline
    inet_state="skipped"
fi

# Overall + exit code, keyed on how many WANs are offline.
offline=0
[[ "$w1_state" == "offline" ]] && offline=$((offline+1))
[[ "$w2_state" == "offline" ]] && offline=$((offline+1))
if   [[ $offline -ge 2 ]]; then OVERALL=down;     EXIT=2
elif [[ $offline -eq 1 ]]; then OVERALL=degraded; EXIT=1
elif [[ "$w1_state" == "degraded" || "$w2_state" == "degraded" ]]; then OVERALL=degraded; EXIT=0
else OVERALL=ok; EXIT=0
fi

TRACE_BLOCK=""
[[ $DO_TRACE -eq 1 ]] && TRACE_BLOCK=$(extract "$PRAW" "tracert ${PING_PUBLIC}")

# ─── RENDER ───────────────────────────────────────────────────
if [[ $JSON_MODE -eq 1 ]]; then
    wan1_obj=$(wan_json "$WAN1_PORT" "$w1_name" "$w1_type" "$w1_status" "$w1_proto" "$w1_ip" "$w1_gw" "$w1_state" "$g1" "$w1_loss" "$w1_rtt" "$lbl1")
    wan2_obj=$(wan_json "$WAN2_PORT" "$w2_name" "$w2_type" "$w2_status" "$w2_proto" "$w2_ip" "$w2_gw" "$w2_state" "$g2" "$w2_loss" "$w2_rtt" "$lbl2")

    internet_obj='null'
    if [[ $DO_PINGS -eq 1 ]]; then
        internet_obj=$(jq -n --arg t "$PING_PUBLIC" --argjson loss "$(jnum "$inet_loss")" \
            --argjson rtt "$(jnum "$inet_rtt")" --arg st "$inet_state" \
            '{target:$t, loss_pct:$loss, rtt_ms:$rtt, state:$st, online:($st!="offline")}')
    fi

    arp_json=$(grep -vE '^[[:space:]]*$|^-+$|MACAdress' <<< "$ARP_BLOCK" \
        | awk 'NF>=4 && $2 ~ /[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/ {print $1"\t"$2"\t"$3"\t"$4}' \
        | jq -R 'split("\t") | {interface:.[0], ip:.[1], mac:.[2], type:.[3]}' | jq -s .)
    [[ -z "$arp_json" ]] && arp_json='[]'

    trace_json='null'
    if [[ $DO_TRACE -eq 1 ]]; then
        trace_json=$(grep -vE '^[[:space:]]*$' <<< "$TRACE_BLOCK" | jq -R . | jq -s .)
        [[ -z "$trace_json" ]] && trace_json='[]'
    fi

    jq -n \
        --arg ts "$(date -Is)" --arg router "$ROUTER_IP" \
        --arg mode "$([[ $TRACE_ONLY -eq 1 ]] && echo trace-only || { [[ $DO_PINGS -eq 1 ]] && echo full || echo fast; })" \
        --argjson wan1 "$wan1_obj" --argjson wan2 "$wan2_obj" \
        --argjson internet "$internet_obj" --arg overall "$OVERALL" \
        --argjson arp "$arp_json" --argjson traceroute "$trace_json" \
        '{timestamp:$ts, router:$router, mode:$mode, overall:$overall,
          wans:[$wan1,$wan2], internet:$internet, arp:$arp, traceroute:$traceroute}'
    exit $EXIT
fi

# Pretty (human) output.
show_wan "$WAN1_BLOCK" "WAN1" "$WAN1_GW" "$WAN1_ISP"
show_wan "$WAN2_BLOCK" "WAN2" "$WAN2_GW" "$WAN2_ISP"

echo -e "${BOLD}── ARP Table ─────────────────────────────────────${RESET}"
grep -vE '^[[:space:]]*$' <<< "$ARP_BLOCK" | sed 's/^/  /'
echo ""

echo -e "${BOLD}${CYAN}══════════════════════════════════════════════${RESET}"
echo -e "${BOLD}  Summary${RESET}"
echo -e "${BOLD}${CYAN}══════════════════════════════════════════════${RESET}"
if [[ $DO_PINGS -eq 1 ]]; then
    summarise_gw "$PRAW" "$g1" "${lbl1} gw "
    summarise_gw "$PRAW" "$g2" "${lbl2} gw "
    ping_result "$(extract "$PRAW" "ping ${PING_PUBLIC}")" "Internet" "$PING_PUBLIC"
    echo ""
    echo -e "  ${CYAN}Note:${RESET} per-WAN lines ping each WAN's own gateway (true per-link health)."
    echo -e "        The Internet line follows the router's active route (load-balance/failover)."
elif [[ $TRACE_ONLY -eq 1 ]]; then
    echo -e "  ${YELLOW}trace-only mode${RESET} — pings skipped; WAN status from link state. Traceroute below."
else
    echo -e "  ${YELLOW}fast mode${RESET} — link status only, connectivity tests skipped."
fi
case "$OVERALL" in
    ok)       OC=$GREEN ;;
    degraded) OC=$YELLOW ;;
    *)        OC=$RED ;;
esac
echo ""
echo -e "  Overall : ${OC}${OVERALL^^}${RESET}  (exit $EXIT)"
echo ""

# ─── Traceroute (opt-in) ──────────────────────────────────────
if [[ $DO_TRACE -eq 1 ]]; then
    echo -e "${BOLD}── Traceroute → ${PING_PUBLIC} ──────────────────────${RESET}"
    if [[ -n "$TRACE_BLOCK" ]]; then
        grep -vE '^[[:space:]]*$' <<< "$TRACE_BLOCK" | sed 's/^/  /'
        echo -e "  ${CYAN}(via the active route — hop 1 shows which WAN it took)${RESET}"
    else
        echo -e "  ${YELLOW}no traceroute output captured${RESET}"
    fi
    echo ""
fi

exit $EXIT
