# Local, site-specific config — never commit (holds router IP / password).
# Exact match, NOT .env* — we want .env.example to stay tracked.
.env

# HA integration's MQTT publisher config (holds broker creds). Same rule: the
# .example stays tracked, the real file does not.
integrations/home-assistant/er605-mqtt.env

# Ubuntu MQTT panel's broker config (holds broker creds).
integrations/ubuntu-panel-mqtt/er605-mqtt-panel.env

# Ubuntu hybrid panel's broker config (holds broker creds).
integrations/ubuntu-panel-hybrid/er605-hybrid.env

# Python bytecode
__pycache__/
*.pyc

# nohup output from launching the panel indicators
nohup.out
