# ER605 checker config — copy to .env and fill in.
#   cp .env.example .env
#   chmod 600 .env          # keep the password readable only by you
# .env is git-ignored, so your real values never reach the repo.
# Anything here can also be overridden by an inline env var or a CLI flag.

# Required
ROUTER_IP=192.168.0.1
ROUTER_PASS=changeme

# Optional (defaults shown)
#ROUTER_USER=admin
#ROUTER_PORT=22
#WAN1_PORT=1
#WAN2_PORT=2
#PING_PUBLIC=8.8.8.8

# Optional: set both to run in ONE SSH login instead of two (saves ~1s).
# Leave blank/unset to auto-discover them live from the router each run.
#WAN1_GW=
#WAN2_GW=
