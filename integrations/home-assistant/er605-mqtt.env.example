# ER605 → MQTT publisher config — copy to er605-mqtt.env and fill in.
#   cp er605-mqtt.env.example er605-mqtt.env
#   chmod 600 er605-mqtt.env
# This file is git-ignored (see repo .gitignore). Router creds still live in the
# repo-root .env (ROUTER_IP/ROUTER_PASS); this file only holds MQTT settings.

# Required: the broker (the Mosquitto add-on on your HAOS Raspberry Pi).
MQTT_HOST=192.168.0.10
MQTT_PORT=1883

# Required: an MQTT login configured in the Mosquitto add-on (logins:).
MQTT_USER=er605
MQTT_PASS=changeme

# Optional (defaults shown).
#MQTT_BASE=er605                 # base topic for status/availability
#DISCOVERY_PREFIX=homeassistant  # HA's MQTT Discovery prefix
#EXPIRE_AFTER=180                # seconds w/o update → entity goes unavailable (~3× interval)

# Optional TLS (port 8883). Leave MQTT_TLS=0 on a trusted LAN.
#MQTT_TLS=0
#MQTT_CAFILE=/etc/ssl/certs/ca-certificates.crt
