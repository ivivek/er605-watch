# ER605 MQTT panel config — copy to er605-mqtt-panel.env and fill in.
#   cp er605-mqtt-panel.env.example er605-mqtt-panel.env
#   chmod 600 er605-mqtt-panel.env
# Git-ignored. The indicator only needs READ access to the broker's status
# topic; a read-only MQTT user is ideal.

# Required: the broker (the Mosquitto add-on on your HAOS box).
MQTT_HOST=192.168.0.10
MQTT_PORT=1883

# Required if the broker enforces auth (it should).
MQTT_USER=er605
MQTT_PASS=changeme

# Optional (defaults shown).
#MQTT_BASE=er605            # base topic; subscribes to <base>/status
#MQTT_TLS=0                 # 1 for TLS (port 8883)
#ER605_STALE_SECS=180       # no update for this long -> show "stale" (≈3× publish interval)
