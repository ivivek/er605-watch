# ER605 hybrid panel config — copy to er605-hybrid.env and fill in.
#   cp er605-hybrid.env.example er605-hybrid.env
#   chmod 600 er605-hybrid.env
# Git-ignored. For DISPLAY the indicator only needs READ access to the broker's
# status topic. The Traceroute action runs er605-watch directly, which reads
# router creds from the repo-root .env (not from this file).

# Required: the broker (the Mosquitto add-on on your HAOS box).
MQTT_HOST=192.168.0.10
MQTT_PORT=1883

# Required if the broker enforces auth (it should).
MQTT_USER=er605
MQTT_PASS=changeme

# Optional (defaults shown).
#MQTT_BASE=er605            # base topic; subscribes to <base>/status
#MQTT_TLS=0                 # 1 for TLS (port 8883)
#ER605_STALE_SECS=180       # no update for this long -> show "stale" (≈3× publish interval)

# Optional: path to er605-watch for the Traceroute action. Defaults to the repo
# root (../../er605-watch relative to the script). Set this if you run the panel
# from a copy that isn't inside the repo checkout.
#ER605_WATCH=/home/<user>/dev/er605/er605-watch
